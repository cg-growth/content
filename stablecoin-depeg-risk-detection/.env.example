# CoinGecko API key.
# REST polling (watchlist.py, poll_depeg.py) works on the free public API with no key.
# WebSocket streaming (stream_depeg.py) requires a paid plan key (Basic and above).
COINGECKO_PRO_API_KEY=your_pro_api_key_here

# Shared secret used to verify CoinGecko webhook signatures (webhook_receiver.py).
# Copy this from your webhook configuration in the CoinGecko developer dashboard.
CG_WEBHOOK_SECRET=your_webhook_signing_secret_here
